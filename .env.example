# Groq API (primary provider)
GROQ_API_KEY=gsk-your-key-here

# Model A — Few-Shot COT with Review Loop (LangGraph)
GROQ_MODEL_A=llama-3.3-70b-versatile

# Model B — Role-Playing Only (LangChain)
GROQ_MODEL_B=llama-3.3-70b-versatile

# Model C — Self-Reflection Agent (LangGraph, 2 rewrite passes)
GROQ_MODEL_C=llama-3.3-70b-versatile

# Judge model for LLM-as-a-Judge metrics
GROQ_JUDGE_MODEL=llama-3.3-70b-versatile
